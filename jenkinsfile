pipeline {
    agent any

    triggers {
        pollSCM('* * * * *')
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking out code...'
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo 'Build stage (Python project)'
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
                sh '''
                python3 <<EOF
from calculator import add, multiply, subtract, divide

assert add(2,3) == 5
assert multiply(2,3) == 6
assert subtract(5,2) == 3
assert divide(10,2) == 5

print("All tests passed")
EOF
                '''
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploy stage (can be SCP to EC2)'
            }
        }
    }
}
 
